<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- User Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ব্যবহারকারী"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUserName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="আপনার নাম" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="নাম সেভ করুন"
            android:layout_marginTop="8dp" />

        <!-- Theme -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="থিম"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="24dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchDarkMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ডার্ক মোড"
            android:layout_marginTop="8dp" />

        <!-- Wake Word -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ওয়েক ওয়ার্ড"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="24dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchWakeWord"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="মেঘা মামুনি ওয়েক ওয়ার্ড"
            android:layout_marginTop="8dp" />

        <!-- Security -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="সিকিউরিটি"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="24dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchPrivacy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="প্রাইভেসি মোড"
            android:layout_marginTop="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSetPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PIN সেট করুন"
            android:layout_marginTop="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchFingerprint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ফিঙ্গারপ্রিন্ট আনলক"
            android:layout_marginTop="8dp" />

        <!-- Clear Data -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ইতিহাস মুছুন"
            android:layout_marginTop="32dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <!-- About -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="মেঘা মামুনি v1.0\nDeveloper: MdRana MsPakhi"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="32dp"
            android:alpha="0.6" />

    </LinearLayout>
</ScrollView>
